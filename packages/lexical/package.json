{
  "name": "lexical",
  "description": "Lexical is an extensible text editor framework that provides excellent reliability, accessible and performance.",
  "keywords": [
    "react",
    "lexical",
    "editor",
    "contenteditable",
    "rich-text"
  ],
  "license": "MIT",
  "version": "0.45.1-nightly.20260604.0",
  "main": "./dist/Lexical.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical"
  },
  "module": "./dist/Lexical.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/Lexical.dev.mjs",
        "production": "./dist/Lexical.prod.mjs",
        "node": "./dist/Lexical.node.mjs",
        "default": "./dist/Lexical.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/Lexical.dev.js",
        "production": "./dist/Lexical.prod.js",
        "default": "./dist/Lexical.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@lexical/internal": "workspace:*"
  }
}
