{
  "name": "@lexical/code-core",
  "description": "This package contains the base functionality code blocks for Lexical, it is a transitional package for internal use while the @lexical/code API is cleaned up.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "code"
  ],
  "license": "MIT",
  "version": "0.44.0",
  "main": "./dist/LexicalCodeCore.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@lexical/extension": "workspace:*",
    "lexical": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-code-core"
  },
  "module": "./dist/LexicalCodeCore.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalCodeCore.dev.mjs",
        "production": "./dist/LexicalCodeCore.prod.mjs",
        "node": "./dist/LexicalCodeCore.node.mjs",
        "default": "./dist/LexicalCodeCore.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalCodeCore.dev.js",
        "production": "./dist/LexicalCodeCore.prod.js",
        "default": "./dist/LexicalCodeCore.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
