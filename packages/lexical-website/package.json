{
  "name": "@lexical/website",
  "version": "0.43.0",
  "private": true,
  "scripts": {
    "docusaurus": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus",
    "start": "pnpm -C ../.. run build && cross-env IGNORE_PEER_DEPENDENCIES=react TYPEDOC_WATCH=true docusaurus start",
    "build": "pnpm -C ../.. run build && cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus build",
