    "deploy": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus deploy",
    "clear": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus clear",
    "serve": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus serve",
    "write-translations": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus write-translations",
    "write-heading-ids": "cross-env IGNORE_PEER_DEPENDENCIES=react docusaurus write-heading-ids"
  },
  "dependencies": {
