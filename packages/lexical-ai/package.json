{
  "name": "@lexical/ai",
  "description": "AI-native plugin for Lexical that exposes editor operations as LLM tools and provides a built-in agent loop.",
  "keywords": [
    "lexical",
    "editor",
    "ai",
    "agent",
    "tools",
    "llm"
  ],
  "license": "MIT",
  "version": "0.42.0",
  "main": "LexicalAI.js",
  "types": "index.d.ts",
  "dependencies": {
    "@lexical/list": "workspace:*",
    "@lexical/link": "workspace:*",
    "@lexical/react": "workspace:*",
    "@lexical/rich-text": "workspace:*",
    "@lexical/utils": "workspace:*",
    "lexical": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-ai"
  },
  "module": "LexicalAI.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "development": "./LexicalAI.dev.mjs",
        "production": "./LexicalAI.prod.mjs",
        "node": "./LexicalAI.node.mjs",
        "default": "./LexicalAI.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "development": "./LexicalAI.dev.js",
        "production": "./LexicalAI.prod.js",
        "default": "./LexicalAI.js"
      }
    }
  }
}
