{
  "name": "@lexical/extension",
  "keywords": [
    "lexical",
    "editor",
    "extension",
    "plugin"
  ],
  "version": "0.46.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-extension"
  },
  "main": "./dist/LexicalExtension.js",
  "types": "./dist/typescript-too-old.d.ts",
  "bugs": {
    "url": "https://github.com/facebook/lexical/issues"
  },
  "homepage": "https://github.com/facebook/lexical#readme",
  "description": "This package provides the extension functionality for Lexical.",
  "sideEffects": false,
  "module": "./dist/LexicalExtension.mjs",
  "dependencies": {
    "@lexical/internal": "workspace:*",
    "@lexical/utils": "workspace:*",
    "@preact/signals-core": "^1.14.1",
    "lexical": "workspace:*"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalExtension.dev.mjs",
        "production": "./dist/LexicalExtension.prod.mjs",
        "node": "./dist/LexicalExtension.node.mjs",
        "default": "./dist/LexicalExtension.mjs"
      },
      "require": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalExtension.dev.js",
        "production": "./dist/LexicalExtension.prod.js",
        "default": "./dist/LexicalExtension.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "./dist/typescript-too-old.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "typescript": ">=5.2"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
