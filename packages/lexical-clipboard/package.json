{
  "name": "@lexical/clipboard",
  "description": "This package provides the copy/paste functionality for Lexical.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "copy",
    "paste"
  ],
  "license": "MIT",
  "version": "0.45.1-nightly.20260603.0",
  "main": "./dist/LexicalClipboard.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@lexical/extension": "workspace:*",
    "@lexical/html": "workspace:*",
    "@lexical/internal": "workspace:*",
    "@lexical/list": "workspace:*",
    "@lexical/selection": "workspace:*",
    "@lexical/utils": "workspace:*",
    "@types/trusted-types": "^2.0.7",
    "lexical": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-clipboard"
  },
  "module": "./dist/LexicalClipboard.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalClipboard.dev.mjs",
        "production": "./dist/LexicalClipboard.prod.mjs",
        "node": "./dist/LexicalClipboard.node.mjs",
        "default": "./dist/LexicalClipboard.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalClipboard.dev.js",
        "production": "./dist/LexicalClipboard.prod.js",
        "default": "./dist/LexicalClipboard.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ]
}
