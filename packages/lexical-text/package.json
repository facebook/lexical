{
  "name": "@lexical/text",
  "description": "This package contains utilities and helpers for handling Lexical text.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "list",
    "text"
  ],
  "license": "MIT",
  "version": "0.44.1-nightly.20260528.0",
  "main": "./dist/LexicalText.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-text"
  },
  "module": "./dist/LexicalText.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalText.dev.mjs",
        "production": "./dist/LexicalText.prod.mjs",
        "node": "./dist/LexicalText.node.mjs",
        "default": "./dist/LexicalText.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalText.dev.js",
        "production": "./dist/LexicalText.prod.js",
        "default": "./dist/LexicalText.js"
      }
    }
  },
  "dependencies": {
    "@lexical/internal": "workspace:*",
    "lexical": "workspace:*"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ]
}
