import type {
  ElementNode,
  ExtensionConfigBase,
  LexicalExtension,
  LexicalNode,
  TextNode,
} from 'lexical';
import type {NamedSignalsOutput} from '@lexical/extension';

// mdast / micromark structures are not Flow-typed; treat them opaquely.
export type MdastNode = mixed;
export type MdastParent = mixed;

export type MdastImportContext = {
  +format: number,
  importChildren(parent: MdastParent, format?: number): Array<LexicalNode>,
  importNode(node: MdastNode, format?: number): Array<LexicalNode>,
  createText(value: string, format?: number): Array<LexicalNode>,
};

export type MdastExportContext = {
  exportChildren(node: ElementNode): Array<MdastNode>,
  exportInline(node: ElementNode): Array<MdastNode>,
  exportBlocks(node: ElementNode): Array<MdastNode>,
};

export type MdastImportHandler = (
  node: MdastNode,
  context: MdastImportContext,
) => LexicalNode | Array<LexicalNode> | null;

export type MdastExportHandler = (
  node: LexicalNode,
  context: MdastExportContext,
) => MdastNode | Array<MdastNode> | null;

export type MdastImportRule = {type: string, $import: MdastImportHandler};
export type MdastExportRule = {type: string, $export: MdastExportHandler};

export type MdastConfig = {
  importRules: $ReadOnlyArray<MdastImportRule>,
  exportRules: $ReadOnlyArray<MdastExportRule>,
  micromarkExtensions: $ReadOnlyArray<mixed>,
  mdastExtensions: $ReadOnlyArray<mixed>,
  toMarkdownExtensions: $ReadOnlyArray<mixed>,
};

export type MdastShortcutsConfig = {disabled: boolean};

export type MdastExtensionOutput = {
  $convertFromMarkdownString(
    markdown: string,
    node?: ElementNode,
    tree?: mixed,
  ): void,
  $convertToMarkdownString(node?: ElementNode): string,
  +registry: mixed,
};

declare export function $convertFromMarkdownStringViaExtension(
  markdown: string,
  node?: ElementNode,
  tree?: mixed,
): void;

declare export function $convertToMarkdownStringViaExtension(
  node?: ElementNode,
): string;

declare export var MdastExtension: LexicalExtension<
  MdastConfig,
  '@lexical/mdast/Mdast',
  MdastExtensionOutput,
  void,
>;
declare export var MdastRichTextExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/RichText',
  void,
  void,
>;
declare export var MdastListExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/List',
  void,
  void,
>;
declare export var MdastCodeExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/Code',
  void,
  void,
>;
declare export var MdastLinkExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/Link',
  void,
  void,
>;
declare export var MdastStrikethroughExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/Strikethrough',
  void,
  void,
>;
declare export var MdastCommonMarkExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/CommonMark',
  void,
  void,
>;
declare export var MdastTableExtension: LexicalExtension<
  ExtensionConfigBase,
  '@lexical/mdast/Table',
  void,
  void,
>;
declare export var MdastShortcutsExtension: LexicalExtension<
  MdastShortcutsConfig,
  '@lexical/mdast/Shortcuts',
  NamedSignalsOutput<MdastShortcutsConfig>,
  void,
>;

export type {ElementNode, ExtensionConfigBase, LexicalNode, TextNode};
