{
  "name": "@lexical/markdown",
  "description": "This package contains Markdown helpers and functionality for Lexical.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "markdown"
  ],
  "license": "MIT",
  "version": "0.44.0",
  "main": "./dist/LexicalMarkdown.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@lexical/code-core": "workspace:*",
    "@lexical/link": "workspace:*",
    "@lexical/list": "workspace:*",
    "@lexical/rich-text": "workspace:*",
    "@lexical/selection": "workspace:*",
    "@lexical/text": "workspace:*",
    "@lexical/utils": "workspace:*",
    "lexical": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-markdown"
  },
  "module": "./dist/LexicalMarkdown.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMarkdown.dev.mjs",
        "production": "./dist/LexicalMarkdown.prod.mjs",
        "node": "./dist/LexicalMarkdown.node.mjs",
        "default": "./dist/LexicalMarkdown.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMarkdown.dev.js",
        "production": "./dist/LexicalMarkdown.prod.js",
        "default": "./dist/LexicalMarkdown.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
