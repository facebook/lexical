{
  "name": "@lexical/mdast",
  "description": "Markdown import, export, and streaming shortcuts for Lexical built on micromark and mdast.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "markdown",
    "mdast",
    "micromark"
  ],
  "license": "MIT",
  "version": "0.45.0",
  "main": "./dist/LexicalMdast.js",
  "types": "./dist/typescript-too-old.d.ts",
  "dependencies": {
    "@lexical/code-core": "workspace:*",
    "@lexical/extension": "workspace:*",
    "@lexical/link": "workspace:*",
    "@lexical/list": "workspace:*",
    "@lexical/rich-text": "workspace:*",
    "@lexical/table": "workspace:*",
    "@lexical/utils": "workspace:*",
    "@types/mdast": "^4.0.4",
    "lexical": "workspace:*",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm-autolink-literal": "^2.0.1",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-gfm-task-list-item": "^2.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "micromark-extension-gfm-autolink-literal": "^2.1.0",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "micromark-extension-gfm-table": "^2.1.1",
    "micromark-extension-gfm-task-list-item": "^2.1.0",
    "micromark-util-types": "^2.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-mdast"
  },
  "module": "./dist/LexicalMdast.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMdast.dev.mjs",
        "production": "./dist/LexicalMdast.prod.mjs",
        "node": "./dist/LexicalMdast.node.mjs",
        "default": "./dist/LexicalMdast.mjs"
      },
      "require": {
        "types@<5.2": "./dist/typescript-too-old.d.ts",
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalMdast.dev.js",
        "production": "./dist/LexicalMdast.prod.js",
        "default": "./dist/LexicalMdast.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ],
  "typesVersions": {
    "*": {
      "*": [
        "./dist/typescript-too-old.d.ts"
      ]
    }
  },
  "peerDependencies": {
    "typescript": ">=5.2"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
