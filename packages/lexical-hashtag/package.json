{
  "name": "@lexical/hashtag",
  "description": "This package contains the functionality for Lexical hashtags.",
  "keywords": [
    "lexical",
    "editor",
    "rich-text",
    "hashtag"
  ],
  "license": "MIT",
  "version": "0.45.1-nightly.20260601.0",
  "main": "./dist/LexicalHashtag.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@lexical/text": "workspace:*",
    "@lexical/utils": "workspace:*",
    "lexical": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebook/lexical.git",
    "directory": "packages/lexical-hashtag"
  },
  "module": "./dist/LexicalHashtag.mjs",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalHashtag.dev.mjs",
        "production": "./dist/LexicalHashtag.prod.mjs",
        "node": "./dist/LexicalHashtag.node.mjs",
        "default": "./dist/LexicalHashtag.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "development": "./dist/LexicalHashtag.dev.js",
        "production": "./dist/LexicalHashtag.prod.js",
        "default": "./dist/LexicalHashtag.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "!src/__bench__",
    "!src/__mocks__",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.bench.ts",
    "!src/**/*.bench.tsx",
    "README.md",
    "LICENSE"
  ]
}
