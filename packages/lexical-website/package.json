    "@lexical/rich-text": "workspace:*",
    "@lexical/selection": "workspace:*",
    "@lexical/utils": "workspace:*",
    "@mdx-js/react": "^3.1.1",
    "@mermaid-js/layout-elk": "^0.2.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
